package br.com.acum3d.Loja;
public class Produto {
    private Long id;
    private String nome;
    private double preco;

    // Construtor (para criarmos a peça rapidamente)
    public Produto(Long id, String nome, double preco) {
        this.id = id;
        this.nome = nome;
        this.preco = preco;
    }

    // Getters: O Spring Boot USA ISSO para ler os dados e transformar em JSON
    public Long getId() {
        return id;
    }

    public String getNome() {
        return nome;
    }

    public double getPreco() {
        return preco;
    }
}