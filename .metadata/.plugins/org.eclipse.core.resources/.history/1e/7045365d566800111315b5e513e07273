# Ele tenta pegar a URL do Render. Se n„o achar, usa o seu local (localhost)
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/acum3d_loja}

# Ele tenta pegar o Usu·rio do Render. Se n„o achar, usa o postgres
spring.datasource.username=${DB_USER:postgres}

# Ele tenta pegar a Senha do Render. Se n„o achar, usa shinagawa
spring.datasource.password=${DB_PASS:shinagawa}

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.datasource.driver-class-name=org.postgresql.Driverver